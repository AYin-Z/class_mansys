# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
.DS_Store
dist
*.local

# Editor directories and files
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment variables
# 默认忽略所有 .env 文件，但显式白名单 .env.example / .env.development，
# 方便多人协作时共享无密的默认配置
**/.env
.env.*.local
.env.local
!.env.example
!.env.development

# Archives
*.zip

# Legacy files
_legacy/

# AI tool directories
.agents/
.codebuddy/
rules/

# Python
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Build output
dist/
build/

# HBuilderX / uni-app
unpackage/
.hbuilderx/
dev-app.log
dev-app.err.log

# HBuilderX CLI 项目识别用的根级硬链接（指向 src/manifest.json 与 src/pages.json）
# 这两个文件是让 HBuilderX 打开项目根时认出 uni-app 项目用的，Git 不需要跟踪
/manifest.json
/pages.json

# Android 签名证书：**绝不能**进 Git
# 如本地自己生成的 keystore 放在项目里，这里拦住
*.keystore
*.jks
*.p12
cert/
certs/

# Capacitor Android 构建产物（android/ 目录整体要提交，但构建产物要排除）
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/app/release/
android/app/debug/
android/captures/

# HBuilderX CLI 打包过程日志（排错辅助，不入仓库）
pack.log
publish.log