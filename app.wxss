/* 全局样式 - 新UI设计系统 */
page {
  background-color: #F5F5F5;
  font-family: 'PingFang SC', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.5;
}

/* 主色调变量 */
:root {
  --primary: #460002;
  --primary-variant: #001E40;
  --surface: #F5F5F5;
  --surface-container: #FFFFFF;
  --on-surface: #1A1A1A;
  --on-surface-variant: #666666;
}

/* 容器样式 */
.container {
  padding: 24rpx;
  background-color: #FFFFFF;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 标题样式 */
.title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #1A1A1A;
}

/* 副标题样式 */
.subtitle {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  color: #666666;
}

/* 内容样式 */
.content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* 按钮样式 */
.btn {
  display: block;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  transition: all 0.2s;
}

.btn-primary {
  background: linear-gradient(135deg, #460002 0%, #001E40 100%);
  color: #ffffff;
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #1A1A1A;
  border: 2rpx solid #E0E0E0;
}

.btn-secondary:active {
  background-color: #F5F5F5;
}

/* 表单样式 */
.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #1A1A1A;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  background: #FFFFFF;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  background: #FFFFFF;
}

/* 列表样式 */
.list {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.list-item {
  padding: 24rpx;
  border-bottom: 2rpx solid #F0F0F0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.list-item-content {
  font-size: 24rpx;
  color: #666666;
  margin-top: 8rpx;
}

/* 状态样式 */
.status {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-pending {
  background-color: rgba(255, 193, 7, 0.1);
  color: #F57C00;
}

.status-approved {
  background-color: rgba(76, 175, 80, 0.1);
  color: #388E3C;
}

.status-rejected {
  background-color: rgba(244, 67, 54, 0.1);
  color: #D32F2F;
}

/* 加载样式 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  color: #666666;
}

/* 空状态样式 */
.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 80rpx 40rpx;
  color: #999999;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  line-height: 1.5;
}

/* 导航样式 */
.nav {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  padding: 24rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.nav-item {
  flex: 1;
  min-width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  border-radius: 16rpx;
  background-color: #F5F5F5;
  transition: all 0.2s;
}

.nav-item:active {
  background-color: #E0E0E0;
  transform: scale(0.98);
}

.nav-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.nav-text {
  font-size: 24rpx;
  color: #1A1A1A;
  text-align: center;
}

/* 分割线样式 */
.divider {
  height: 2rpx;
  background-color: #F0F0F0;
  margin: 24rpx 0;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.card-time {
  font-size: 22rpx;
  color: #999999;
}

.card-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* 消息提示样式 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  padding: 24rpx 48rpx;
  background-color: rgba(0, 0, 0, 0.7);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
  z-index: 9999;
  text-align: center;
}

/* 遮罩层样式 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 9998;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 弹出框样式 */
.popup {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.15);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.popup-close {
  font-size: 40rpx;
  color: #999999;
}

.popup-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.popup-footer {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
}

/* 玻璃拟态效果 */
.glass-effect {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* 渐变背景 */
.gradient-primary {
  background: linear-gradient(135deg, #460002 0%, #001E40 100%);
}

/* 可点击卡片效果 */
.actionable-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.actionable-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* 安全区域适配 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-area-top {
  padding-top: env(safe-area-inset-top);
}

/* 响应式样式 */
@media (max-width: 375px) {
  .container {
    padding: 20rpx;
  }
  
  .title {
    font-size: 28rpx;
  }
  
  .subtitle {
    font-size: 24rpx;
  }
  
  .btn {
    height: 80rpx;
    line-height: 80rpx;
    font-size: 26rpx;
  }
  
  .form-input,
  .form-textarea {
    height: 80rpx;
    padding: 0 20rpx;
  }
  
  .form-textarea {
    min-height: 160rpx;
    padding: 20rpx;
  }
  
  .list-item {
    padding: 20rpx;
  }
  
  .nav {
    gap: 16rpx;
    padding: 20rpx;
  }
  
  .nav-item {
    min-width: 140rpx;
    padding: 20rpx;
  }
  
  .card {
    padding: 20rpx;
  }
  
  .popup {
    width: 90%;
    padding: 32rpx;
  }
}
