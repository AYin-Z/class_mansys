# 数据库配置
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=class_manage_sys
DB_PORT=3306

# JWT配置
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=24h

# 服务器配置
PORT=3000
NODE_ENV=development

# 微信小程序配置
APPID=your_wechat_appid
APPSECRET=your_wechat_appsecret

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5mb