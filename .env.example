# ============================================================
# 区队管理系统前端 · 环境变量模板
# ------------------------------------------------------------
# 使用方法：
#   1. 复制一份到 .env.local（个人本地覆盖；已被 .gitignore 忽略）
#   2. 生产构建用 .env.production，开发运行用 .env.development
#   3. 所有 VITE_ 前缀的变量才会注入到浏览器/小程序前端，其余只作用于 Vite 配置
#
# 优先级：
#   .env.{mode}.local  >  .env.{mode}  >  .env.local  >  .env
# ============================================================

# ---- 后端 API 地址（必填）----
# 开发/灰度：可填 CloudRun 测试域名（*.sh.run.tcloudbase.com）
# 正式发版：必须填已备案的自定义 HTTPS 域名，并在微信公众平台 request合法域名 中添加同域名
VITE_API_BASE_URL=https://class-manage-sys-247928-5-1420593393.sh.run.tcloudbase.com

# ---- CloudBase 环境 ID（Web / H5 场景使用）----
VITE_ENV_ID=clamansys-xxxxxxxxxxxxxxxx

# ---- CloudBase 公开密钥（Web 端匿名访问令牌；保密性低）----
VITE_PUBLISHABLE_KEY=

# ---- 可选：小程序 AppID（正式发版需要）----
# 也可以在 src/manifest.json 里填 mp-weixin.appid
# VITE_WX_APPID=wx1234567890abcdef
